            card.MouseEnter:Connect(function()
                Utils.tween(card, TweenInfo.new(0.15), {BackgroundTransparency = 0.3})
            end)
            card.MouseLeave:Connect(function()
                Utils.tween(card, TweenInfo.new(0.15), {BackgroundTransparency = 0.5})
            end)
        end

        return card, toggleBg, toggleKnob, toggleStroke, toggleBtn, toggleW, toggleH, knobSz
    end

    local function setToggleActive(toggleBg, toggleKnob, toggleStroke, active, toggleW, knobSz)
        Utils.tween(toggleBg, TweenInfo.new(0.2), {BackgroundColor3 = active and Colors.toggleOn or Colors.toggleOff})
        Utils.tween(toggleStroke, TweenInfo.new(0.2), {
            Color = active and Colors.accent or Colors.divider,
            Transparency = active and 0 or 0.7
        })
        Utils.tween(toggleKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Position = active
                and UDim2.new(1, -(knobSz + 2), 0.5, -knobSz/2)
                or  UDim2.new(0, 2, 0.5, -knobSz/2)
        })
    end

