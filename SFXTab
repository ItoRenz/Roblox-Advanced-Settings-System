    squidBtn.Activated:Connect(function() switchWalkSound("SQUIDWARD", SQUIDWARD_WALK_ID) end)
    spongeBtn.MouseButton1Click:Connect(function() switchWalkSound("SPONGEBOB", SPONGEBOB_WALK_ID) end)
    spongeBtn.Activated:Connect(function() switchWalkSound("SPONGEBOB", SPONGEBOB_WALK_ID) end)
    krabBtn.MouseButton1Click:Connect(function() switchWalkSound("MRKRAB", MRKRAB_WALK_ID) end)
    krabBtn.Activated:Connect(function() switchWalkSound("MRKRAB", MRKRAB_WALK_ID) end)
end

-- ═══════════════════════════════════════════════
-- SETUP & CLEANUP
-- ═══════════════════════════════════════════════
local function setupConnections()
    if not humanoid then return end
    jumpConnection   = humanoid.Jumping:Connect(onJump)
    runConnection    = humanoid.Running:Connect(handleWalking)
    stateConnection  = humanoid.StateChanged:Connect(handleStateChanged)
    heartbeatConnection = game:GetService("RunService").Heartbeat:Connect(ensureSoundPlaying)
end

local function cleanupConnections()
    if jumpConnection   then jumpConnection:Disconnect() end
    if runConnection    then runConnection:Disconnect() end
    if stateConnection  then stateConnection:Disconnect() end
    if heartbeatConnection then heartbeatConnection:Disconnect() end
end

function SFXTab.setup()
    -- PATCH: Tunggu karakter jika belum ada
    local function initWithCharacter(char)
        character = char
        humanoid = character:WaitForChild("Humanoid")
        rootPart = character:WaitForChild("HumanoidRootPart")
        hideDefaultSounds(character)
        setupCustomSounds()
        lastJumpTime = 0
        isWalking = false
        isJumping = false
        cleanupConnections()
        setupConnections()
    end

    if character then
        initWithCharacter(character)
    end

    player.CharacterAdded:Connect(function(newChar)
        initWithCharacter(newChar)
    end)

    print("✅ SFX Tab: Setup complete")
end

function SFXTab.cleanup()
    cleanupConnections()
    if jumpSound then jumpSound:Destroy() end
    if walkSound then walkSound:Destroy() end
    print("🔇 SFX Tab cleaned up")
end

return SFXTab
