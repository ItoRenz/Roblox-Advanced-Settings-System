        noAddCard.BackgroundTransparency = 0.6
        noAddCard.BorderSizePixel = 0
        noAddCard.ZIndex = 202
        noAddCard.LayoutOrder = 3
        noAddCard.Parent = contentScroll
        utils.corner(noAddCard, 10)

