function MusicPlayer:showNotification(message, notifType)
    if not self.ui.notificationContainer then return end
    local colors = _G.AdvancedSettings.colors
    local isMobile = _G.AdvancedSettings.isMobile
    local isConsole = _G.AdvancedSettings and _G.AdvancedSettings.isConsole or false
    local utils = _G.AdvancedSettings.utils

    local bgColor = colors.card
    local textColor = colors.text
    local icon = "ℹ️"
    if notifType == "error" then bgColor = colors.bad; textColor = Color3.new(1,1,1); icon = "❌"
    elseif notifType == "success" then bgColor = colors.good; textColor = Color3.new(1,1,1); icon = "✅"
    elseif notifType == "warning" then bgColor = Color3.fromRGB(255,180,0); textColor = Color3.new(1,1,1); icon = "⚠️" end

    local toastW = isConsole and 420 or (isMobile and 240 or 380)
    local toastH = isConsole and 80 or (isMobile and 60 or 90)
    local pad = isConsole and 24 or (isMobile and 8 or 20)

    local toast = Instance.new("Frame")
    toast.Size = UDim2.new(0, toastW, 0, toastH)
    toast.Position = UDim2.new(1, -(toastW + pad), 0, pad)
    toast.BackgroundColor3 = bgColor
    toast.BackgroundTransparency = 0.1
    toast.BorderSizePixel = 0
    toast.ZIndex = 1000
    toast.Parent = self.ui.notificationContainer
    utils.corner(toast, isConsole and 14 or (isMobile and 10 or 16))

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, isConsole and 60 or (isMobile and 40 or 50), 1, 0)
    iconLabel.Position = UDim2.new(0, 10, 0, 0)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Text = icon
    iconLabel.TextColor3 = textColor
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.TextSize = isConsole and 28 or (isMobile and 20 or 28)
    iconLabel.ZIndex = 1001
    iconLabel.Parent = toast

    local msgLabel = Instance.new("TextLabel")
    msgLabel.Size = UDim2.new(1, isConsole and -80 or (isMobile and -56 or -70), 1, 0)
    msgLabel.Position = UDim2.new(0, isConsole and 72 or (isMobile and 48 or 60), 0, 0)
    msgLabel.BackgroundTransparency = 1
    msgLabel.Text = message
    msgLabel.TextColor3 = textColor
    msgLabel.Font = Enum.Font.GothamBold
    msgLabel.TextSize = isConsole and 15 or (isMobile and 9 or 12)
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.TextWrapped = true
    msgLabel.ZIndex = 1001
    msgLabel.Parent = toast

    -- Animate in & out
    toast.Position = UDim2.new(1, pad, 0, pad)
    utils.tween(toast, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -(toastW + pad), 0, pad)
    })
    task.delay(2.5, function()
        utils.tween(toast, TweenInfo.new(0.3), {
            Position = UDim2.new(1, pad, 0, pad),
            BackgroundTransparency = 1
        })
        task.delay(0.3, function()
            if toast.Parent then toast:Destroy() end
        end)
    end)
end

function MusicPlayer:init()
    if self.initialized then return end
    self.initialized = true

    -- Load playlist
    for _, song in ipairs(self.defaultPlaylist) do
        table.insert(self.playlist, {id = song.id, title = song.title, favorite = false})
    end

    self:loadSound()
    debugPrint("✅ MusicPlayer initialized, songs:", #self.playlist)
end

