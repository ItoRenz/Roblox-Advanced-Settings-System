    local volTrackW = isConsole and 200 or (isMobile and 120 or 160)
    local volBg = Instance.new("Frame")
    volBg.Size = UDim2.new(0, volTrackW, 0, isConsole and 8 or 6)
    volBg.Position = UDim2.new(0, pad + (isConsole and 88 or 66), 0, volY + volH/2 - (isConsole and 4 or 3))
    volBg.BackgroundColor3 = colors.toggleOff
    volBg.BorderSizePixel = 0
    volBg.ZIndex = 203
    volBg.Parent = playerCard
    utils.corner(volBg, 4)

    local volFill = Instance.new("Frame")
    volFill.Size = UDim2.new(MusicPlayer.state.volume / 10, 0, 1, 0)
    volFill.BackgroundColor3 = colors.accent
    volFill.BorderSizePixel = 0
    volFill.ZIndex = 204
    volFill.Parent = volBg
    utils.corner(volFill, 4)

    local volValLabel = Instance.new("TextLabel")
    volValLabel.Size = UDim2.new(0, 30, 0, volH)
    volValLabel.Position = UDim2.new(0, pad + (isConsole and 296 or 234), 0, volY)
    volValLabel.BackgroundTransparency = 1
    volValLabel.Text = tostring(MusicPlayer.state.volume)
    volValLabel.TextColor3 = colors.accent
    volValLabel.Font = Enum.Font.GothamBold
    volValLabel.TextSize = isConsole and 14 or (isMobile and 9 or 11)
    volValLabel.ZIndex = 203
    volValLabel.Parent = playerCard

    -- Volume slider drag (PC/Mobile)
    if not isConsole then
        local volDragging = false
        local volHitbox = Instance.new("TextButton")
        volHitbox.Size = UDim2.new(1, 0, 3, 0)
        volHitbox.AnchorPoint = Vector2.new(0, 0.5)
        volHitbox.Position = UDim2.new(0, 0, 0.5, 0)
        volHitbox.BackgroundTransparency = 1
        volHitbox.Text = ""
        volHitbox.ZIndex = 205
        volHitbox.Parent = volBg

        local function updateVol(input)
            local rel = math.clamp((input.Position.X - volBg.AbsolutePosition.X) / volBg.AbsoluteSize.X, 0, 1)
            local v = math.floor(rel * 10 + 0.5)
            MusicPlayer:setVolume(v)
            volFill.Size = UDim2.new(v / 10, 0, 1, 0)
            volValLabel.Text = tostring(v)
        end

        volHitbox.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or
               input.UserInputType == Enum.UserInputType.Touch then
                volDragging = true
                updateVol(input)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if volDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
               input.UserInputType == Enum.UserInputType.Touch) then
                updateVol(input)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or
               input.UserInputType == Enum.UserInputType.Touch then
                volDragging = false
            end
        end)
    else
        -- PATCH: Console volume via DPad Up/Down
        UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if not playerCard.Parent then return end
            if not playerCard:IsDescendantOf(game:GetService("Players").LocalPlayer.PlayerGui) then return end
            local v = MusicPlayer.state.volume
            if input.KeyCode == Enum.KeyCode.DPadUp then
                v = math.clamp(v + 1, 0, 10)
                MusicPlayer:setVolume(v)
                volFill.Size = UDim2.new(v / 10, 0, 1, 0)
                volValLabel.Text = tostring(v)
            elseif input.KeyCode == Enum.KeyCode.DPadDown then
                v = math.clamp(v - 1, 0, 10)
                MusicPlayer:setVolume(v)
                volFill.Size = UDim2.new(v / 10, 0, 1, 0)
                volValLabel.Text = tostring(v)
            end
        end)
    end

    -- ════════════════════════════════
    -- PLAYLIST TOGGLE BUTTON
    -- ════════════════════════════════
