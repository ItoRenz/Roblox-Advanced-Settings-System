        noAddLabel.Size = UDim2.new(1, -20, 1, 0)
        noAddLabel.Position = UDim2.new(0, 10, 0, 0)
        noAddLabel.BackgroundTransparency = 1
        noAddLabel.Text = "⚠️  Add Custom Song not available on console"
        noAddLabel.TextColor3 = colors.textDark
        noAddLabel.Font = Enum.Font.Gotham
        noAddLabel.TextSize = 14
        noAddLabel.TextXAlignment = Enum.TextXAlignment.Left
        noAddLabel.ZIndex = 203
        noAddLabel.Parent = noAddCard
    end

    -- Update loop
    if MusicPlayer.updateLoop then MusicPlayer.updateLoop:Disconnect() end
    MusicPlayer.updateLoop = RunService.Heartbeat:Connect(function()
        if MusicPlayer.state.isPlaying and MusicPlayer.sound and MusicPlayer.sound.IsPlaying then
            MusicPlayer:updateProgress()
        end
    end)

    MusicPlayer:updateUI()
    MusicPlayer:updatePlaylistDisplay()
    MusicPlayer.uiCreated = true

    -- PATCH: Console gamepad music controls (global, saat menu terbuka)
    if isConsole then
        UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if not _G.AdvancedSettings.menuOpen then return end
            if _G.AdvancedSettings.activeTab ~= "MUSIC" then return end

            if input.KeyCode == Enum.KeyCode.ButtonA then
                MusicPlayer:togglePlay()
            elseif input.KeyCode == Enum.KeyCode.ButtonL1 then
                MusicPlayer:prevSong()
            elseif input.KeyCode == Enum.KeyCode.ButtonR1 then
                MusicPlayer:nextSong()
            end
        end)
    end
end

-- ═══════════════════════════════════════════════
-- TAB INTERFACE
-- ═══════════════════════════════════════════════
function MusicTab.setup()
    task.spawn(function()
        task.wait(1)
        MusicPlayer:init()
    end)
    debugPrint("✅ Music Tab: Setup Complete")
end

function MusicTab.cleanup()
    if MusicPlayer.updateLoop then
        MusicPlayer.updateLoop:Disconnect()
        MusicPlayer.updateLoop = nil
    end
    if MusicPlayer.characterConn then
        MusicPlayer.characterConn:Disconnect()
        MusicPlayer.characterConn = nil
    end
    if MusicPlayer.sound then
        MusicPlayer.sound:Stop()
        MusicPlayer.sound:Destroy()
        MusicPlayer.sound = nil
    end
    debugPrint("🧹 Music Tab: Cleanup Complete")
end

return MusicTab
