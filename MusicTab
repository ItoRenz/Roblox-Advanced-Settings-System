        MusicPlayer.state.showPlaylist = not MusicPlayer.state.showPlaylist
        playlistPanel.Visible = MusicPlayer.state.showPlaylist
        plBtn.Text = ICONS.PLAYLIST .. (MusicPlayer.state.showPlaylist and "  Hide Playlist" or "  Show Playlist (" .. #MusicPlayer.playlist .. " songs)")
        if MusicPlayer.state.showPlaylist then
            MusicPlayer:updatePlaylistDisplay()
        end
