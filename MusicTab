function MusicPlayer:getCurrentSong()
    if #self.playlist == 0 then return nil end
    return self.playlist[self.state.currentIndex]
end

function MusicPlayer:loadSound()
    if not self.sound then
        self.sound = Instance.new("Sound")
        self.sound.Name = "MusicPlayerSound"
        self.sound.Parent = SoundService
        self.sound.Looped = false
        self.sound.Volume = self.state.volume / 10

        self.sound.Ended:Connect(function()
            if self.state.isPlaying then
                self:nextSong()
            end
        end)
    end
end

function MusicPlayer:playSong(index)
    local song = self.playlist[index]
    if not song then return end
    self.state.currentIndex = index
    self.state.isLoading = true
    self:loadSound()
    self.sound:Stop()
    self.sound.SoundId = song.id
    self.sound.Volume = self.state.volume / 10
    self.sound:Play()
    self.state.isPlaying = true
    self.state.isLoading = false
    self:updateUI()
    debugPrint("▶ Playing:", song.title)
end

function MusicPlayer:togglePlay()
    if not self.sound then self:loadSound() end
    if self.state.isPlaying then
        self.sound:Pause()
        self.state.isPlaying = false
    else
        if self.sound.SoundId == "" then
            self:playSong(self.state.currentIndex)
        else
            self.sound:Resume()
            self.state.isPlaying = true
        end
    end
    self:updateUI()
end

function MusicPlayer:nextSong()
    local count = #self.playlist
    if count == 0 then return end
    local nextIndex
    if self.state.loopMode == "one" then
        nextIndex = self.state.currentIndex
    elseif self.state.shuffle then
        nextIndex = math.random(1, count)
    else
        nextIndex = (self.state.currentIndex % count) + 1
    end
    self:playSong(nextIndex)
end

function MusicPlayer:prevSong()
    local count = #self.playlist
    if count == 0 then return end
    local prevIndex
    if self.state.shuffle then
        prevIndex = math.random(1, count)
    else
        prevIndex = self.state.currentIndex - 1
        if prevIndex < 1 then prevIndex = count end
    end
    self:playSong(prevIndex)
end

function MusicPlayer:toggleShuffle()
    self.state.shuffle = not self.state.shuffle
    self:updateUI()
end

function MusicPlayer:toggleLoop()
    if self.state.loopMode == "all" then
        self.state.loopMode = "one"
    elseif self.state.loopMode == "one" then
        self.state.loopMode = "none"
    else
        self.state.loopMode = "all"
    end
    self:updateUI()
end

function MusicPlayer:setVolume(val)
    self.state.volume = val
    if self.sound then
        self.sound.Volume = val / 10
    end
end

function MusicPlayer:addCustomSong(id, title)
    local cleanId = id:gsub("[^%d]", "")
    if cleanId == "" then
        self:showNotification("Invalid Sound ID!", "error")
        return false
    end
    local fullId = "rbxassetid://" .. cleanId
    table.insert(self.customSongs, {id = fullId, title = title, favorite = false})
    table.insert(self.playlist, {id = fullId, title = title, favorite = false})
    self:showNotification("Added: " .. title, "success")
    self:updatePlaylistDisplay()
    return true
end

function MusicPlayer:updateProgress()
    if not self.sound or not self.ui.progressFill then return end
    local total = self.sound.TimeLength
    local current = self.sound.TimePosition
    if total > 0 then
        self.ui.progressFill.Size = UDim2.new(current / total, 0, 1, 0)
        if self.ui.timeLabel then
            local function fmt(t)
                local m = math.floor(t / 60)
                local s = math.floor(t % 60)
                return string.format("%d:%02d", m, s)
            end
            self.ui.timeLabel.Text = fmt(current) .. " / " .. fmt(total)
        end
    end
end

function MusicPlayer:updateUI()
    if not self.uiCreated then return end
    -- Play/Pause icon
    if self.ui.playBtn then
        self.ui.playBtn.Text = self.state.isPlaying and ICONS.PAUSE or ICONS.PLAY
    end
    -- Song title
    local song = self:getCurrentSong()
    if self.ui.songTitle then
        self.ui.songTitle.Text = song and song.title or "No Song"
    end
    -- Shuffle
    if self.ui.shuffleBtn then
        local colors = _G.AdvancedSettings.colors
        self.ui.shuffleBtn.TextColor3 = self.state.shuffle and colors.accent or colors.textGray
    end
    -- Loop
    if self.ui.loopBtn then
        local colors = _G.AdvancedSettings.colors
        local loopText = self.state.loopMode == "all" and ICONS.LOOP_ALL
                      or self.state.loopMode == "one" and ICONS.LOOP_ONE
                      or "○"
        self.ui.loopBtn.Text = loopText
        self.ui.loopBtn.TextColor3 = self.state.loopMode ~= "none"
            and colors.accent or colors.textGray
    end
end

