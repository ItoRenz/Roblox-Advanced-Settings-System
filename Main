contentLayout.Padding = UDim.new(0, isConsole and 14 or (isMobile and 8 or 12))
contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
contentLayout.Parent = contentScroll
contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    contentScroll.CanvasSize = UDim2.new(0,0,0,contentLayout.AbsoluteContentSize.Y+20)
end)

-- ═══════════════════════════════════════════════
-- TAB SYSTEM
-- ═══════════════════════════════════════════════

function _G.AdvancedSettings.registerTab(id, name, order, createContentFunc, setupFunc, cleanupFunc)
    table.insert(_G.AdvancedSettings.tabs, {
        id = id,
        name = name,
        order = order,
        createContent = createContentFunc,
        setup = setupFunc,
        cleanup = cleanupFunc
    })
    table.sort(_G.AdvancedSettings.tabs, function(a, b)
        return a.order < b.order
    end)
    print("✅ Tab registered: " .. name)
end

local function updateTabUI()
    for id, components in pairs(_G.AdvancedSettings.tabButtons) do
        local isActive = (id == _G.AdvancedSettings.activeTab)
        Utils.tween(components.btn, TweenInfo.new(0.25), {BackgroundTransparency = isActive and 0.6 or 1})
        Utils.tween(components.indicator, TweenInfo.new(0.25), {BackgroundTransparency = isActive and 0 or 1})
        Utils.tween(components.label, TweenInfo.new(0.25), {TextColor3 = isActive and Colors.text or Colors.textGray})
    end
end

local function createTabButton(data)
    local tabBtn = Instance.new("TextButton")
    tabBtn.Name = data.id
    -- PATCH: Tab button lebih tinggi di console
    tabBtn.Size = UDim2.new(1,-10,0, isConsole and 56 or (isMobile and 35 or 45))
    tabBtn.BackgroundColor3 = Colors.card
    tabBtn.BackgroundTransparency = 1
    tabBtn.BorderSizePixel = 0
    tabBtn.Text = ""
    tabBtn.AutoButtonColor = false
    tabBtn.ZIndex = 202
    tabBtn.LayoutOrder = data.order
    tabBtn.Parent = tabContainer
    Utils.corner(tabBtn, 8)

    -- PATCH: Console - aktifkan Selectable agar bisa di-navigate dengan D-pad
    if isConsole then
        tabBtn.Selectable = true
    end

    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0,3,1,-10)
    indicator.Position = UDim2.new(0,0,0,5)
    indicator.BackgroundColor3 = Colors.accent
    indicator.BorderSizePixel = 0
    indicator.BackgroundTransparency = 1
    indicator.ZIndex = 203
    indicator.Parent = tabBtn
    Utils.corner(indicator, 2)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,-15,1,0)
    label.Position = UDim2.new(0, isConsole and 18 or (isMobile and 8 or 15), 0, 0)
    label.BackgroundTransparency = 1
    label.Text = data.name
    label.TextColor3 = Colors.textGray
    label.Font = Enum.Font.GothamBold
    -- PATCH: Text lebih besar di console
    label.TextSize = isConsole and 16 or (isMobile and 10 or 14)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 204
    label.Parent = tabBtn

    _G.AdvancedSettings.tabButtons[data.id] = {
        btn = tabBtn,
        indicator = indicator,
        label = label
    }

    -- Click handler (PC & Mobile)
    tabBtn.MouseButton1Click:Connect(function()
        _G.AdvancedSettings.activeTab = data.id
        updateTabUI()
        _G.AdvancedSettings.updateContent()
    end)

    -- PATCH: Console - Activated event juga support ButtonA gamepad
    tabBtn.Activated:Connect(function()
        _G.AdvancedSettings.activeTab = data.id
        updateTabUI()
        _G.AdvancedSettings.updateContent()
    end)

    -- Hover (PC only, tidak perlu di console/mobile)
    if not isConsole then
        tabBtn.MouseEnter:Connect(function()
            if _G.AdvancedSettings.activeTab ~= data.id then
                Utils.tween(tabBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0.7})
            end
        end)
        tabBtn.MouseLeave:Connect(function()
            if _G.AdvancedSettings.activeTab ~= data.id then
                Utils.tween(tabBtn, TweenInfo.new(0.15), {BackgroundTransparency = 1})
            end
        end)
    end

    return tabBtn
end

function _G.AdvancedSettings.updateContent()
    for _, child in ipairs(contentScroll:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    local activeTabData = nil
    for _, tab in ipairs(_G.AdvancedSettings.tabs) do
        if tab.id == _G.AdvancedSettings.activeTab then
            activeTabData = tab
            break
        end
    end
    if activeTabData and activeTabData.createContent then
        activeTabData.createContent(contentScroll, Colors, isMobile, Utils)
    end
end

-- ═══════════════════════════════════════════════
-- MENU TOGGLE
-- ═══════════════════════════════════════════════

function _G.AdvancedSettings.toggleMenu()
    _G.AdvancedSettings.menuOpen = not _G.AdvancedSettings.menuOpen

    if _G.AdvancedSettings.menuOpen then
        -- Sembunyikan button (PC/Mobile only)
        if not isConsole then
            Utils.tween(btn, TweenInfo.new(0.2), {BackgroundTransparency = 1})
            Utils.tween(btnStroke, TweenInfo.new(0.2), {Transparency = 1})
            Utils.tween(icon, TweenInfo.new(0.2), {TextTransparency = 1})
            task.delay(0.2, function() btn.Visible = false end)
        end

        backdrop.Visible = true
        panel.Visible = true
        Utils.tween(backdrop, TweenInfo.new(0.35), {BackgroundTransparency = 0.25})

        panel.Size = UDim2.new(0,0,0,0)
        panel.Position = UDim2.new(0.5,0,0.5,0)

        Utils.tween(panel, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = panelSize
        })

        -- PATCH: Console - set GamepadService selection ke tab pertama
        if isConsole then
            task.delay(0.4, function()
                local firstTab = _G.AdvancedSettings.tabButtons[_G.AdvancedSettings.activeTab]
                if firstTab then
                    GuiService.SelectedObject = firstTab.btn
                end
            end)
        end

        updateTabUI()
        _G.AdvancedSettings.updateContent()
    else
        Utils.tween(backdrop, TweenInfo.new(0.25), {BackgroundTransparency = 1})
        Utils.tween(panel, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.new(0,0,0,0)
        })

        -- PATCH: Console - clear selection saat menu ditutup
        if isConsole then
            GuiService.SelectedObject = nil
        end

        task.delay(0.25, function()
            backdrop.Visible = false
            panel.Visible = false
            if not isConsole then
                btn.Visible = true
                btn.BackgroundTransparency = 1
                btnStroke.Transparency = 1
                icon.TextTransparency = 1
                Utils.tween(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.15})
                Utils.tween(btnStroke, TweenInfo.new(0.2), {Transparency = 0.4})
                Utils.tween(icon, TweenInfo.new(0.2), {TextTransparency = 0})
            end
        end)
    end
end

-- ═══════════════════════════════════════════════
-- EVENT CONNECTIONS
-- ═══════════════════════════════════════════════

task.wait(0.2)

-- PC & Mobile: tombol ⚙
pcall(function()
    btn.MouseButton1Click:Connect(_G.AdvancedSettings.toggleMenu)
end)

pcall(function()
    closeBtn.MouseButton1Click:Connect(_G.AdvancedSettings.toggleMenu)
end)

-- PATCH: Console — closeBtn juga bisa di-activate dengan ButtonA
pcall(function()
    closeBtn.Activated:Connect(_G.AdvancedSettings.toggleMenu)
end)

pcall(function()
    backdrop.MouseButton1Click:Connect(_G.AdvancedSettings.toggleMenu)
end)

-- Hover untuk close button (PC/Mobile only)
if not isConsole then
    closeBtn.MouseEnter:Connect(function()
        if closeBtn.Parent then
            Utils.tween(closeBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0.3})
        end
    end)
    closeBtn.MouseLeave:Connect(function()
        if closeBtn.Parent then
            Utils.tween(closeBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0.5})
        end
    end)
end

-- ═══════════════════════════════════════════════
-- PATCH: GAMEPAD INPUT — CONSOLE CONTROLS
-- ButtonStart  = Toggle open/close menu
-- ButtonB      = Close menu
-- LB (L1)      = Tab sebelumnya
-- RB (R1)      = Tab berikutnya
-- ═══════════════════════════════════════════════
if isConsole or UIS.GamepadEnabled then
    UIS.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end

        -- START = toggle menu
        if input.KeyCode == Enum.KeyCode.ButtonStart then
            _G.AdvancedSettings.toggleMenu()

        -- B = close menu
        elseif input.KeyCode == Enum.KeyCode.ButtonB then
            if _G.AdvancedSettings.menuOpen then
                _G.AdvancedSettings.toggleMenu()
            end

        -- LB = tab sebelumnya
        elseif input.KeyCode == Enum.KeyCode.ButtonL1 then
            if _G.AdvancedSettings.menuOpen then
                local tabs = _G.AdvancedSettings.tabs
                local currentIdx = 1
                for i, tab in ipairs(tabs) do
                    if tab.id == _G.AdvancedSettings.activeTab then
                        currentIdx = i
                        break
                    end
                end
                local newIdx = math.max(1, currentIdx - 1)
                _G.AdvancedSettings.activeTab = tabs[newIdx].id
                updateTabUI()
                _G.AdvancedSettings.updateContent()
            end

        -- RB = tab berikutnya
        elseif input.KeyCode == Enum.KeyCode.ButtonR1 then
            if _G.AdvancedSettings.menuOpen then
                local tabs = _G.AdvancedSettings.tabs
                local currentIdx = 1
                for i, tab in ipairs(tabs) do
                    if tab.id == _G.AdvancedSettings.activeTab then
                        currentIdx = i
                        break
                    end
                end
                local newIdx = math.min(#tabs, currentIdx + 1)
                _G.AdvancedSettings.activeTab = tabs[newIdx].id
                updateTabUI()
                _G.AdvancedSettings.updateContent()
            end
        end
    end)
end

-- ═══════════════════════════════════════════════
-- LOAD TABS
-- ═══════════════════════════════════════════════

task.wait(0.5)

for _, tab in ipairs(_G.AdvancedSettings.tabs) do
    createTabButton(tab)
    if tab.setup then
        task.spawn(tab.setup)
    end
end

updateTabUI()
_G.AdvancedSettings.updateContent()

