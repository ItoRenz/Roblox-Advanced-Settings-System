}

-- ═══════════════════════════════════════════════
-- UTILITY FUNCTIONS
-- ═══════════════════════════════════════════════
local Utils = {}

function Utils.corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius)
    c.Parent = parent
    return c
end

function Utils.tween(object, tweenInfo, properties)
    TweenService:Create(object, tweenInfo, properties):Play()
end

