-- ═══════════════════════════════════════════════
-- PATCH: PLATFORM DETECTION
-- ═══════════════════════════════════════════════
local isMobile = UIS.TouchEnabled and not UIS.KeyboardEnabled
local isConsole = not UIS.KeyboardEnabled and not UIS.TouchEnabled and UIS.GamepadEnabled
local isTenFoot = GuiService:IsTenFootInterface() -- true saat di console/TV

-- Log platform untuk debug
print("📱 Platform Detection:")
print("  isMobile:", isMobile)
print("  isConsole:", isConsole)
print("  isTenFoot:", isTenFoot)

