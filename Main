-- Tab Section
-- PATCH: Tab section lebih lebar di console
local tabSectionWidth = isConsole and 240 or (isMobile and 110 or 200)

local tabSection = Instance.new("Frame")
tabSection.Size = UDim2.new(0, tabSectionWidth, 1, -headerHeight)
tabSection.Position = UDim2.new(0,0,0,headerHeight)
tabSection.BackgroundColor3 = Colors.panel
tabSection.BackgroundTransparency = 0.7
tabSection.BorderSizePixel = 0
tabSection.ZIndex = 201
tabSection.Parent = panel

local tabContainer = Instance.new("ScrollingFrame")
tabContainer.Size = UDim2.new(1,-8,1,-16)
tabContainer.Position = UDim2.new(0,4,0,8)
tabContainer.BackgroundTransparency = 1
tabContainer.BorderSizePixel = 0
tabContainer.ScrollBarThickness = isConsole and 0 or 3  -- PATCH: hide scrollbar di console
tabContainer.ScrollBarImageColor3 = Colors.accent
tabContainer.ScrollBarImageTransparency = 0.5
tabContainer.ScrollingDirection = Enum.ScrollingDirection.Y
tabContainer.CanvasSize = UDim2.new(0,0,0,0)
tabContainer.ElasticBehavior = Enum.ElasticBehavior.Never
tabContainer.ZIndex = 201
tabContainer.Parent = tabSection

-- Anti horizontal & vertical over-scroll untuk tabs
tabContainer:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
    if tabContainer.CanvasPosition.X ~= 0 then
        tabContainer.CanvasPosition = Vector2.new(0, tabContainer.CanvasPosition.Y)
    end
    local maxScroll = tabContainer.CanvasSize.Y.Offset - tabContainer.AbsoluteSize.Y
    if maxScroll <= 0 then
        tabContainer.CanvasPosition = Vector2.new(0, 0)
        return
    end
    if tabContainer.CanvasPosition.Y < 0 then
        tabContainer.CanvasPosition = Vector2.new(0, 0)
    elseif tabContainer.CanvasPosition.Y > maxScroll then
        tabContainer.CanvasPosition = Vector2.new(0, maxScroll)
    end
end)

local tabLayout = Instance.new("UIListLayout")
tabLayout.Padding = UDim.new(0, isConsole and 6 or 4)
tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
tabLayout.Parent = tabContainer
tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    tabContainer.CanvasSize = UDim2.new(0,0,0,tabLayout.AbsoluteContentSize.Y+8)
end)

-- Content Area
