local function createVolumeSlider(parent, labelText, layoutOrder, initialValue, callback, colors, isMobile, utils)
    -- PATCH: ambil isConsole dari global
    local isConsole = _G.AdvancedSettings and _G.AdvancedSettings.isConsole or false

    local sliderFrame = Instance.new("Frame")
    sliderFrame.Name = "SliderFrame_" .. labelText
    sliderFrame.Size = UDim2.new(1, -4, 0, isConsole and 90 or (isMobile and 70 or 85))
    sliderFrame.BackgroundColor3 = colors.card
    sliderFrame.BackgroundTransparency = 0.4
    sliderFrame.BorderSizePixel = 0
    sliderFrame.ZIndex = 202
    sliderFrame.LayoutOrder = layoutOrder
    sliderFrame.Parent = parent
    utils.corner(sliderFrame, 12)

    local sliderStroke = Instance.new("UIStroke")
    sliderStroke.Color = colors.divider
    sliderStroke.Thickness = 1
    sliderStroke.Transparency = 0.6
    sliderStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    sliderStroke.Parent = sliderFrame

    -- Label
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0.6, 0, 0, isConsole and 28 or (isMobile and 18 or 22))
    nameLabel.Position = UDim2.new(0, isConsole and 14 or (isMobile and 10 or 14), 0, isConsole and 10 or (isMobile and 6 or 8))
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = labelText
    nameLabel.TextColor3 = colors.text
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = isConsole and 16 or (isMobile and 10 or 13)
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.ZIndex = 203
    nameLabel.Parent = sliderFrame

    -- Value label
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0.35, 0, 0, isConsole and 28 or (isMobile and 18 or 22))
    valueLabel.Position = UDim2.new(0.65, 0, 0, isConsole and 10 or (isMobile and 6 or 8))
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(initialValue)
    valueLabel.TextColor3 = colors.accent
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = isConsole and 18 or (isMobile and 12 or 15)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.ZIndex = 203
    valueLabel.Parent = sliderFrame

    -- Slider track area
    local trackY = isConsole and 46 or (isMobile and 30 or 38)
    local trackHeight = isConsole and 10 or (isMobile and 6 or 8)

    local sliderBg = Instance.new("TextButton")
    sliderBg.Size = UDim2.new(1, isConsole and -120 or (isMobile and -90 or -100), 0, trackHeight)
    sliderBg.Position = UDim2.new(0, isConsole and 14 or (isMobile and 10 or 14), 0, trackY)
    sliderBg.BackgroundColor3 = colors.toggleOff
    sliderBg.BorderSizePixel = 0
    sliderBg.Text = ""
    sliderBg.AutoButtonColor = false
    sliderBg.ZIndex = 203
    sliderBg.Parent = sliderFrame
    utils.corner(sliderBg, trackHeight / 2)

    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new(initialValue / 10, 0, 1, 0)
    sliderFill.BackgroundColor3 = colors.accent
    sliderFill.BorderSizePixel = 0
    sliderFill.ZIndex = 204
    sliderFill.Parent = sliderBg
    utils.corner(sliderFill, trackHeight / 2)

    -- Knob
    local knobSize = isConsole and 22 or (isMobile and 14 or 18)
    local knobHitbox = Instance.new("TextButton")
    knobHitbox.Size = UDim2.new(0, knobSize * 2, 0, knobSize * 2)
    knobHitbox.AnchorPoint = Vector2.new(0.5, 0.5)
    knobHitbox.Position = UDim2.new(initialValue / 10, 0, 0.5, 0)
    knobHitbox.BackgroundTransparency = 1
    knobHitbox.Text = ""
    knobHitbox.ZIndex = 206
    knobHitbox.Parent = sliderBg

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, knobSize, 0, knobSize)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(0.5, 0, 0.5, 0)
    knob.BackgroundColor3 = colors.text
    knob.BorderSizePixel = 0
    knob.ZIndex = 205
    knob.Parent = knobHitbox
    utils.corner(knob, knobSize / 2)

    -- Mute / Max buttons
    local btnY = isConsole and 48 or (isMobile and 32 or 40)
    local btnW = isConsole and 44 or (isMobile and 30 or 36)
    local btnH = isConsole and 28 or (isMobile and 18 or 22)
    local btnTextSize = isConsole and 13 or (isMobile and 8 or 10)
    local rightPad = isConsole and 14 or (isMobile and 10 or 14)

    local btnMax = Instance.new("TextButton")
    btnMax.Size = UDim2.new(0, btnW, 0, btnH)
    btnMax.Position = UDim2.new(1, -(rightPad), 0, btnY - (btnH - trackHeight) / 2)
    btnMax.BackgroundColor3 = colors.accent
    btnMax.BackgroundTransparency = 0.2
    btnMax.BorderSizePixel = 0
    btnMax.Text = "MAX"
    btnMax.TextColor3 = colors.bg
    btnMax.Font = Enum.Font.GothamBold
    btnMax.TextSize = btnTextSize
    btnMax.ZIndex = 204
    btnMax.AutoButtonColor = false
    btnMax.Parent = sliderFrame
    utils.corner(btnMax, 5)

    local btnMute = Instance.new("TextButton")
    btnMute.Size = UDim2.new(0, btnW, 0, btnH)
    btnMute.Position = UDim2.new(1, -(rightPad + btnW + 6), 0, btnY - (btnH - trackHeight) / 2)
    btnMute.BackgroundColor3 = colors.card
    btnMute.BackgroundTransparency = 0.3
    btnMute.BorderSizePixel = 0
    btnMute.Text = "MUTE"
    btnMute.TextColor3 = colors.text
    btnMute.Font = Enum.Font.GothamBold
    btnMute.TextSize = btnTextSize
    btnMute.ZIndex = 204
    btnMute.AutoButtonColor = false
    btnMute.Parent = sliderFrame
    utils.corner(btnMute, 5)

    -- PATCH: Console hint
    if isConsole then
        local hintLabel = Instance.new("TextLabel")
        hintLabel.Size = UDim2.new(1, -28, 0, 20)
        hintLabel.Position = UDim2.new(0, 14, 0, 64)
        hintLabel.BackgroundTransparency = 1
        hintLabel.Text = "◄ ► D-Pad to adjust"
        hintLabel.TextColor3 = colors.textDark
        hintLabel.Font = Enum.Font.Gotham
        hintLabel.TextSize = 12
        hintLabel.TextXAlignment = Enum.TextXAlignment.Left
        hintLabel.ZIndex = 203
        hintLabel.Parent = sliderFrame
    end

    -- ════════════════════════════
    -- SLIDER LOGIC
    -- ════════════════════════════
    local dragging = false
    local smoothValue = initialValue
    local committedValue = initialValue

    local function updateSliderUI(value, snap)
        local frac = value / 10
        sliderFill.Size = UDim2.new(frac, 0, 1, 0)
        knobHitbox.Position = UDim2.new(frac, 0, 0.5, 0)
        valueLabel.Text = tostring(snap and math.floor(value + 0.5) or math.floor(value))
    end

    local function updateSliderFromInput(input)
        local sliderAbsPos = sliderBg.AbsolutePosition.X
        local sliderAbsSize = sliderBg.AbsoluteSize.X
        local relX = math.clamp((input.Position.X - sliderAbsPos) / sliderAbsSize, 0, 1)
        local rawValue = relX * 10
        smoothValue = rawValue
        updateSliderUI(rawValue, false)
        local intValue = math.floor(smoothValue + 0.5)
        committedValue = intValue
        if callback then callback(intValue) end
    end

    local function startDragging(input)
        dragging = true
        updateSliderFromInput(input)
    end

    local function stopDragging()
        if not dragging then return end
        dragging = false
        local finalValue = math.floor(smoothValue + 0.5)
        smoothValue = finalValue
        updateSliderUI(finalValue, true)
        if finalValue ~= committedValue then
            committedValue = finalValue
            if callback then callback(finalValue) end
        end
    end

    -- PC: RenderStepped smooth tracking
    local renderConnection
    local inputConnection

    if not isMobile and not isConsole then
        renderConnection = RunService.RenderStepped:Connect(function()
            if dragging then
                local mousePos = UserInputService:GetMouseLocation()
                local fakeInput = { Position = Vector3.new(mousePos.X, mousePos.Y, 0) }
                updateSliderFromInput(fakeInput)
            end
        end)
    elseif isMobile then
        inputConnection = UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.Touch then
                updateSliderFromInput(input)
            end
        end)
    end

    -- Mouse/Touch input
    knobHitbox.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            startDragging(input)
        end
    end)

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            startDragging(input)
        end
    end)

    knobHitbox.MouseButton1Down:Connect(function(x, y)
        startDragging({ Position = Vector3.new(x, y, 0) })
    end)

    sliderBg.MouseButton1Down:Connect(function(x, y)
        startDragging({ Position = Vector3.new(x, y, 0) })
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            stopDragging()
        end
    end)

    -- PATCH: Console — DPad Left/Right untuk adjust slider
    -- Hanya aktif saat sliderFrame visible dan menu terbuka
    if isConsole then
        local dpadConnection
        dpadConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if not sliderFrame.Parent then
                dpadConnection:Disconnect()
                return
            end
            -- Cek apakah tab ini sedang aktif (sliderFrame visible di screen)
            if not sliderFrame:IsDescendantOf(game:GetService("Players").LocalPlayer.PlayerGui) then return end

            local step = 1 -- per klik DPad = naik/turun 1
            if input.KeyCode == Enum.KeyCode.DPadRight or input.KeyCode == Enum.KeyCode.Thumbstick1 then
                -- Thumbstick1 handled via InputChanged below
            end

            if input.KeyCode == Enum.KeyCode.DPadRight then
                local newVal = math.clamp(committedValue + step, 0, 10)
                committedValue = newVal
                smoothValue = newVal
                updateSliderUI(newVal, true)
                if callback then callback(newVal) end
            elseif input.KeyCode == Enum.KeyCode.DPadLeft then
                local newVal = math.clamp(committedValue - step, 0, 10)
                committedValue = newVal
                smoothValue = newVal
                updateSliderUI(newVal, true)
                if callback then callback(newVal) end
            end
        end)

        -- Thumbstick untuk fine control
        UserInputService.InputChanged:Connect(function(input)
            if not sliderFrame.Parent then return end
            if not sliderFrame:IsDescendantOf(game:GetService("Players").LocalPlayer.PlayerGui) then return end
            if input.UserInputType == Enum.UserInputType.Gamepad1 and
               input.KeyCode == Enum.KeyCode.Thumbstick1 then
                local x = input.Position.X
                if math.abs(x) > 0.5 then
                    local delta = x > 0 and 1 or -1
                    local newVal = math.clamp(committedValue + delta, 0, 10)
                    committedValue = newVal
                    smoothValue = newVal
                    updateSliderUI(newVal, true)
                    if callback then callback(newVal) end
                end
            end
        end)
    end

    -- Mute / Max buttons
    local function onMute()
        smoothValue = 0
        committedValue = 0
        updateSliderUI(0, true)
        if callback then callback(0) end
    end

    local function onMax()
        smoothValue = 10
        committedValue = 10
        updateSliderUI(10, true)
        if callback then callback(10) end
    end

    btnMute.MouseButton1Click:Connect(onMute)
    btnMax.MouseButton1Click:Connect(onMax)
    -- PATCH: Console support untuk tombol Mute/Max
    btnMute.Activated:Connect(onMute)
    btnMax.Activated:Connect(onMax)

    -- Cleanup
    sliderFrame.Destroying:Connect(function()
        if renderConnection then renderConnection:Disconnect() end
        if inputConnection then inputConnection:Disconnect() end
    end)

    return sliderFrame, valueLabel
end

