function AudioTab.setup()
    task.spawn(function()
        task.wait(0.5)
        AudioManager:init()
    end)
    print("✅ Audio Tab: Setup complete")
end

function AudioTab.cleanup()
    AudioManager:cleanup()
    print("🧹 Audio Tab: Cleanup complete")
end

return AudioTab
