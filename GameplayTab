        btn.Font = Enum.Font.GothamBold
        btn.TextSize = fontSize
        btn.Parent = g
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = btn
        return btn
    end

    -- LEFT SIDE: Movement (Cross layout)
    local upBtn    = createBtn("▲", UDim2.new(0, 10 + btnWidth + spacing, 1, -10 - btnHeight*2 - spacing))
    local leftBtn  = createBtn("◄", UDim2.new(0, 10, 1, -10 - btnHeight))
    local rightBtn = createBtn("►", UDim2.new(0, 10 + (btnWidth+spacing)*2, 1, -10 - btnHeight))
    local downBtn  = createBtn("▼", UDim2.new(0, 10 + btnWidth + spacing, 1, -10 - btnHeight))

    -- RIGHT SIDE: Rotation + Zoom
    local rotUpBtn   = createBtn("UP", UDim2.new(1, -10 - btnWidth*2 - spacing, 1, -10 - btnHeight*2 - spacing))
    local zoomOutBtn = createBtn("-",  UDim2.new(1, -10 - btnWidth*3 - spacing*2, 1, -10 - btnHeight))
    local zoomInBtn  = createBtn("+",  UDim2.new(1, -10 - btnWidth, 1, -10 - btnHeight))
    local rotDownBtn = createBtn("DN", UDim2.new(1, -10 - btnWidth*2 - spacing, 1, -10 - btnHeight))

    -- PATCH: Console hint label di tengah atas
    if isConsole then
        local hintLabel = Instance.new("TextLabel")
        hintLabel.Size = UDim2.new(0, 480, 0, 36)
        hintLabel.Position = UDim2.new(0.5, -240, 0, 16)
        hintLabel.BackgroundColor3 = Color3.new(0,0,0)
        hintLabel.BackgroundTransparency = 0.4
        hintLabel.BorderSizePixel = 0
        hintLabel.Text = "🎮  L-Stick=Move  R-Stick=Rotate  DPad↑↓=Zoom  B=Exit"
        hintLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        hintLabel.Font = Enum.Font.Gotham
        hintLabel.TextSize = 14
        hintLabel.Parent = g
        local hCorner = Instance.new("UICorner")
        hCorner.CornerRadius = UDim.new(0, 8)
        hCorner.Parent = hintLabel
    end

    self.gui = g

    -- Button setup helper
    local function setupButton(btn, directionFunc)
        btn.MouseButton1Down:Connect(function()
            directionFunc(true)
            self:showButtons()
        end)
        btn.MouseButton1Up:Connect(function() directionFunc(false) end)
        btn.MouseLeave:Connect(function() directionFunc(false) end)
        btn.TouchTap:Connect(function()
            directionFunc(true)
            self:showButtons()
            task.wait(0.1)
            directionFunc(false)
        end)
    end

    setupButton(upBtn,    function(s) self.moveUp    = s end)
    setupButton(downBtn,  function(s) self.moveDown  = s end)
    setupButton(leftBtn,  function(s) self.moveLeft  = s end)
    setupButton(rightBtn, function(s) self.moveRight = s end)
    setupButton(rotUpBtn,   function(s) self.rotUp   = s end)
    setupButton(rotDownBtn, function(s) self.rotDown = s end)
    setupButton(zoomInBtn,  function(s) self.zoomIn  = s end)
    setupButton(zoomOutBtn, function(s) self.zoomOut = s end)
end

function scripts.freecam:toggle(isMobile, isConsole)
    self.enabled = not self.enabled
    self.isMobile = isMobile
    self.isConsole = isConsole or false

    if self.enabled then
        if _G.AdvancedSettings.menuOpen then
            _G.AdvancedSettings.toggleMenu()
        end

        self.origCFrame  = self.cam.CFrame
        self.origCamType = self.cam.CameraType
        self.origCamSub  = self.cam.CameraSubject

        self.cam.CameraType = Enum.CameraType.Scriptable

        self:hideGameUI()
        self:hideTitles()

        if not self.gui then self:createUI(isMobile, isConsole) end
        if self.gui then self.gui.Enabled = true end

        -- Reset state flags
        self.moveUp = false; self.moveDown = false
        self.moveLeft = false; self.moveRight = false
        self.rotUp = false; self.rotDown = false
        self.zoomIn = false; self.zoomOut = false
        self.leftStick = Vector2.zero
        self.rightStick = Vector2.zero
        self.lastInteraction = tick()

        -- Auto-hide timer
        if self.hideTimer then self.hideTimer:Disconnect() end
        self.hideTimer = RunService.Heartbeat:Connect(function()
            if self.enabled and tick() - self.lastInteraction > 3 then
                self:hideButtons()
            end
        end)

        -- ════════════════════════════════
        -- MAIN MOVEMENT LOOP
        -- ════════════════════════════════
        table.insert(self.conns, RunService.RenderStepped:Connect(function(dt)
            if not self.enabled then return end

            local moveDelta = Vector3.zero

            -- PC/Mobile: button flags
            if self.moveUp    then moveDelta = moveDelta + Vector3.new(0, self.moveSpeed, 0) end
            if self.moveDown  then moveDelta = moveDelta - Vector3.new(0, self.moveSpeed, 0) end
            if self.moveLeft  then moveDelta = moveDelta - (self.cam.CFrame.RightVector * self.moveSpeed) end
            if self.moveRight then moveDelta = moveDelta + (self.cam.CFrame.RightVector * self.moveSpeed) end

            -- PATCH: Console LeftThumbstick = gerak (strafe + maju/mundur)
            if isConsole then
                local ls = self.leftStick
                if math.abs(ls.X) > 0.1 then
                    moveDelta = moveDelta + (self.cam.CFrame.RightVector * ls.X * self.moveSpeed)
                end
                if math.abs(ls.Y) > 0.1 then
                    moveDelta = moveDelta + (self.cam.CFrame.LookVector * ls.Y * self.moveSpeed)
                end
            end

            if moveDelta.Magnitude > 0 then
                self.cam.CFrame = self.cam.CFrame + moveDelta
                self.cam.Focus = self.cam.CFrame
            end

            -- Rotation (PC/Mobile buttons)
            if self.rotUp then
                self.cam.CFrame = self.cam.CFrame * CFrame.Angles(self.rotSpeed, 0, 0)
                self.cam.Focus = self.cam.CFrame
            end
            if self.rotDown then
                self.cam.CFrame = self.cam.CFrame * CFrame.Angles(-self.rotSpeed, 0, 0)
                self.cam.Focus = self.cam.CFrame
            end

            -- PATCH: Console RightThumbstick = rotasi kamera
            if isConsole then
                local rs = self.rightStick
                if math.abs(rs.X) > 0.1 or math.abs(rs.Y) > 0.1 then
                    -- Yaw (kiri/kanan) = world Y axis
                    -- Pitch (atas/bawah) = local X axis
                    local yaw   = -rs.X * self.rotSpeed
                    local pitch =  rs.Y * self.rotSpeed
                    self.cam.CFrame = self.cam.CFrame
                        * CFrame.Angles(pitch, 0, 0)
                    self.cam.CFrame = CFrame.new(self.cam.CFrame.Position)
                        * CFrame.Angles(0, yaw, 0)
                        * CFrame.Angles(pitch, 0, 0)
                        * CFrame.new(0, 0, 0)

                    -- Simpler but effective rotation
                    self.cam.CFrame = self.cam.CFrame
                        * CFrame.Angles(pitch, yaw, 0)
                    self.cam.Focus = self.cam.CFrame
                end
            end

            -- Zoom (PC/Mobile buttons + console DPad)
            if self.zoomIn then
                self.cam.CFrame = self.cam.CFrame + (self.cam.CFrame.LookVector * self.zoomSpeed)
                self.cam.Focus = self.cam.CFrame
            end
            if self.zoomOut then
                self.cam.CFrame = self.cam.CFrame - (self.cam.CFrame.LookVector * self.zoomSpeed)
                self.cam.Focus = self.cam.CFrame
            end
        end))

        -- PC Mouse: drag to rotate + scroll to zoom
        if not isMobile and not isConsole then
            local mouseDown = false
            local lastMousePos = nil

            table.insert(self.conns, UserInputService.InputBegan:Connect(function(input, gpe)
                if not self.enabled then return end
                if input.UserInputType == Enum.UserInputType.MouseButton2 then
                    mouseDown = true
                    lastMousePos = UserInputService:GetMouseLocation()
                end
            end))

            table.insert(self.conns, UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton2 then
                    mouseDown = false
                    lastMousePos = nil
                end
            end))

            table.insert(self.conns, UserInputService.InputChanged:Connect(function(input, gpe)
                if not self.enabled then return end
                if input.UserInputType == Enum.UserInputType.MouseWheel then
                    local zoomAmount = input.Position.Z * self.zoomSpeed
                    self.cam.CFrame = self.cam.CFrame + (self.cam.CFrame.LookVector * zoomAmount)
                    self.cam.Focus = self.cam.CFrame
                    self:showButtons()
                end
                if mouseDown and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local currentPos = UserInputService:GetMouseLocation()
                    if lastMousePos then
                        local delta = currentPos - lastMousePos
                        local yaw   = -delta.X * 0.003
                        local pitch = -delta.Y * 0.003
                        self.cam.CFrame = CFrame.new(self.cam.CFrame.Position)
                            * CFrame.Angles(0, yaw, 0)
                            * CFrame.Angles(pitch, 0, 0)
                        self.cam.Focus = self.cam.CFrame
                    end
                    lastMousePos = currentPos
                end
            end))
        end

        -- PATCH: Console thumbstick input via InputChanged
        if isConsole then
            table.insert(self.conns, UserInputService.InputChanged:Connect(function(input)
                if not self.enabled then return end
                if input.UserInputType == Enum.UserInputType.Gamepad1 then
                    if input.KeyCode == Enum.KeyCode.Thumbstick1 then
                        self.leftStick = Vector2.new(input.Position.X, input.Position.Y)
                        self:showButtons()
                    elseif input.KeyCode == Enum.KeyCode.Thumbstick2 then
                        self.rightStick = Vector2.new(input.Position.X, input.Position.Y)
                        self:showButtons()
                    end
                end
            end))

            -- PATCH: Console DPad Up/Down = zoom, B = exit freecam
            table.insert(self.conns, UserInputService.InputBegan:Connect(function(input, gp)
                if gp then return end
                if not self.enabled then return end
                if input.KeyCode == Enum.KeyCode.DPadUp then
                    self.zoomIn = true
                elseif input.KeyCode == Enum.KeyCode.DPadDown then
                    self.zoomOut = true
                elseif input.KeyCode == Enum.KeyCode.ButtonB then
                    -- B = exit freecam
                    self:toggle(isMobile, isConsole)
                end
            end))

            table.insert(self.conns, UserInputService.InputEnded:Connect(function(input)
                if not self.enabled then return end
                if input.KeyCode == Enum.KeyCode.DPadUp then
                    self.zoomIn = false
                elseif input.KeyCode == Enum.KeyCode.DPadDown then
                    self.zoomOut = false
                end
            end))
        end

        -- Mobile touch show buttons
        table.insert(self.conns, UserInputService.TouchStarted:Connect(function(touch, gpe)
            if self.enabled then self:showButtons() end
        end))

        -- PC keyboard movement (WASD + QE)
        if not isMobile and not isConsole then
            table.insert(self.conns, RunService.RenderStepped:Connect(function()
                if not self.enabled then return end
                self.moveForward  = UserInputService:IsKeyDown(Enum.KeyCode.W)
                self.moveBackward = UserInputService:IsKeyDown(Enum.KeyCode.S)
                self.moveLeft2    = UserInputService:IsKeyDown(Enum.KeyCode.A)
                self.moveRight2   = UserInputService:IsKeyDown(Enum.KeyCode.D)
                local upKey       = UserInputService:IsKeyDown(Enum.KeyCode.E)
                local downKey     = UserInputService:IsKeyDown(Enum.KeyCode.Q)
                local speed = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and self.moveSpeed * 3 or self.moveSpeed

                local delta = Vector3.zero
                if self.moveForward  then delta = delta + self.cam.CFrame.LookVector * speed end
                if self.moveBackward then delta = delta - self.cam.CFrame.LookVector * speed end
                if self.moveLeft2    then delta = delta - self.cam.CFrame.RightVector * speed end
                if self.moveRight2   then delta = delta + self.cam.CFrame.RightVector * speed end
                if upKey   then delta = delta + Vector3.new(0, speed, 0) end
                if downKey then delta = delta - Vector3.new(0, speed, 0) end

                if delta.Magnitude > 0 then
                    self.cam.CFrame = self.cam.CFrame + delta
                    self.cam.Focus = self.cam.CFrame
                end
            end))
        end

    else
        -- DISABLE FREECAM
        if self.hideTimer then
            self.hideTimer:Disconnect()
            self.hideTimer = nil
        end
        for _, conn in ipairs(self.conns) do
            pcall(function() conn:Disconnect() end)
        end
        self.conns = {}

        -- Reset thumbstick state
        self.leftStick = Vector2.zero
        self.rightStick = Vector2.zero
        self.zoomIn = false
        self.zoomOut = false

        self.cam.CameraType = self.origCamType or Enum.CameraType.Custom
        self.cam.CameraSubject = self.origCamSub

        if self.gui then self.gui.Enabled = false end
        self:showGameUI()
        self:showTitles()
    end

    if self.toggleUI then self.toggleUI(self.enabled) end
    return self.enabled
end

